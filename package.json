{
  "name": "mcp-query",
  "version": "0.0.1",
  "description": "A reactive, cached, embeddable MCP client for non-agentic apps. TanStack Query keys + RTK Query tags + LSP-client lifecycle, on top of the official MCP SDK.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "workspaces": [
    "apps/*"
  ],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./react": { "types": "./dist/react/index.d.ts", "default": "./dist/react/index.js" },
    "./devtools": { "types": "./dist/devtools/index.d.ts", "default": "./dist/devtools/index.js" },
    "./testing": { "types": "./dist/testing/mockServer.d.ts", "default": "./dist/testing/mockServer.js" },
    "./webmcp": { "types": "./dist/webmcp/index.d.ts", "default": "./dist/webmcp/index.js" },
    "./server": { "types": "./dist/server/index.d.ts", "default": "./dist/server/index.js" },
    "./session": { "types": "./dist/session/index.d.ts", "default": "./dist/session/index.js" },
    "./metrics": { "types": "./dist/metrics/index.d.ts", "default": "./dist/metrics/index.js" },
    "./redis": { "types": "./dist/redis/index.d.ts", "default": "./dist/redis/index.js" }
  },
  "bin": {
    "mcp-query-codegen": "./dist/codegen/cli.js",
    "mcp-query-inspect": "./dist/cli/inspect.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/codegen/cli.js dist/cli/inspect.js",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "codegen": "tsx src/codegen/cli.ts",
    "inspect": "tsx src/cli/inspect.ts",
    "example:node": "tsx examples/node-everything.ts",
    "example:01": "tsx examples/01-minimal.ts",
    "example:02": "tsx examples/02-cache-and-invalidation.ts",
    "example:03": "tsx examples/03-live-subscriptions.ts",
    "example:04": "tsx examples/04-multi-server.ts",
    "example:05": "tsx examples/05-human-in-the-loop.ts",
    "example:06": "tsx examples/06-alongside-another-client.ts"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "react": "^19.2.7"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.6",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
