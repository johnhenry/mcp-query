{
  "name": "mcp-query",
  "version": "0.0.1",
  "description": "A reactive, cached, embeddable MCP client for non-agentic apps. TanStack Query keys + RTK Query tags + LSP-client lifecycle, on top of the official MCP SDK.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react/index.ts",
    "./devtools": "./src/devtools/index.ts",
    "./testing": "./src/testing/mockServer.ts"
  },
  "bin": {
    "mcp-query-codegen": "./src/codegen/cli.ts",
    "mcp-query-inspect": "./src/cli/inspect.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen": "tsx src/codegen/cli.ts",
    "inspect": "tsx src/cli/inspect.ts",
    "example:node": "tsx examples/node-everything.ts",
    "example:01": "tsx examples/01-minimal.ts",
    "example:02": "tsx examples/02-cache-and-invalidation.ts",
    "example:03": "tsx examples/03-live-subscriptions.ts",
    "example:04": "tsx examples/04-multi-server.ts",
    "example:05": "tsx examples/05-human-in-the-loop.ts",
    "example:06": "tsx examples/06-alongside-another-client.ts"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "react": "^19.2.7"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "happy-dom": "^20.10.6",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
