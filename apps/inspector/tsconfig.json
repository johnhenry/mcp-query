{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["vite/client", "node"],
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "paths": {
      "mcp-query": ["../../src/index.ts"],
      "mcp-query/devtools": ["../../src/devtools/protocol.ts"],
      "mcp-query/webmcp": ["../../src/webmcp/index.ts"]
    }
  },
  "include": ["src", "server", "vite.config.ts"]
}
