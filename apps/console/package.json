{
  "name": "@mcp-query/console",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "MCP Console — a Web Components + Vite mcp-query example app with the shared WS proxy.",
  "scripts": {
    "dev": "WEB_PORT=5174 PROXY_PORT=6281 concurrently -n proxy,web -c magenta,cyan \"npm:dev:proxy\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:proxy": "tsx ../shared/src/proxy-cli.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mcp-query/app-shared": "*",
    "mcp-query": "*"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "happy-dom": "^20.10.6",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.9",
    "ws": "^8.18.0"
  }
}
